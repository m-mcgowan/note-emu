; Copy this file to secrets.ini and fill in your values.
; secrets.ini is gitignored and will not be committed.
;
; Uses build_src_flags (additive) rather than build_flags (replacement)
; so it merges with the main platformio.ini flags.

[env:wokwi]
build_src_flags =
    '-DNOTEHUB_PAT="your-notehub-api-token"'
    '-DNOTEHUB_PRODUCT="com.example.softcard"'

[env:hardware]
build_src_flags =
    '-DWIFI_SSID="your-ssid"'
    '-DWIFI_PASS="your-password"'
    '-DNOTEHUB_PAT="your-notehub-api-token"'
    '-DNOTEHUB_PRODUCT="com.example.softcard"'
